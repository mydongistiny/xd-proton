From 9a0a81019faf5bc837ac3e464703fc2ff608a538 Mon Sep 17 00:00:00 2001
From: Etaash Mathamsetty
 <45927311+Etaash-mathamsetty@users.noreply.github.com>
Date: Thu, 15 Jan 2026 23:39:53 -0500
Subject: [PATCH 108/113] user32: Implement dead key support for
 MapVirtualKeyExA.

---
 dlls/user32/input.c | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/dlls/user32/input.c b/dlls/user32/input.c
index 11b4b617e33..22f65c6a875 100644
--- a/dlls/user32/input.c
+++ b/dlls/user32/input.c
@@ -270,18 +270,22 @@ UINT WINAPI MapVirtualKeyW(UINT code, UINT maptype)
  */
 UINT WINAPI MapVirtualKeyExA(UINT code, UINT maptype, HKL hkl)
 {
+    UINT top_bit = 0;
     UINT ret;
 
     ret = NtUserMapVirtualKeyEx( code, maptype, hkl );
     if (maptype == MAPVK_VK_TO_CHAR)
     {
         BYTE ch = 0;
-        WCHAR wch = ret;
+        WCHAR wch;
+
+        top_bit = ret & (1u << 31);
+        wch = ret & ~top_bit;
 
         WideCharToMultiByte( CP_ACP, 0, &wch, 1, (LPSTR)&ch, 1, NULL, NULL );
         ret = ch;
     }
-    return ret;
+    return ret | top_bit;
 }
 
